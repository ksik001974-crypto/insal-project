generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Complaint {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  analysis    String?
  violated    String?
  reason      String?
  problemPart String?
  riskScore   Int?
  status      String   @default("미처리")
  createdAt   DateTime @default(now())
}